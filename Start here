<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>About — Chirpbase Reads</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --cream: #F7F3EC;
    --ink: #1A1410;
    --rust: #B85C38;
    --rust-light: #F0D5C8;
    --sage: #4A5E4B;
    --sage-light: #D4E0D5;
    --gold: #C9963A;
    --gold-light: #F5E8CF;
    --muted: #6B6058;
    --border: #D9D2C8;
  }

  body {
    background: var(--cream);
    color: var(--ink);
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    line-height: 1.7;
  }

  /* NAV */
  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 4rem;
    border-bottom: 1px solid var(--border);
    background: var(--cream);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-brand {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .nav-eyebrow {
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 400;
  }

  .nav-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--ink);
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
  }

  .nav-links a {
    text-decoration: none;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 400;
    transition: color 0.2s;
  }

  .nav-links a:hover, .nav-links a.active { color: var(--ink); }

  /* HERO */
  .about-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 60vh;
    border-bottom: 1px solid var(--border);
  }

  .about-hero-left {
    padding: 5rem 4rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    border-right: 1px solid var(--border);
  }

  .page-tag {
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--rust);
    font-weight: 500;
    margin-bottom: 1.2rem;
  }

  .about-headline {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 4vw, 3.8rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .about-headline em {
    font-style: italic;
    color: var(--rust);
  }

  .about-sub {
    font-size: 1rem;
    color: var(--muted);
    line-height: 1.8;
    max-width: 420px;
  }

  .about-hero-right {
    background: var(--ink);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 4rem;
    gap: 1.5rem;
  }

  .about-hero-right img {
    height: 130px;
    width: auto;
  }

  .about-hero-tagline {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-style: italic;
    color: rgba(247,243,236,0.7);
    text-align: center;
    line-height: 1.6;
    max-width: 300px;
  }

  /* SECTIONS */
  .content-section {
    display: grid;
    grid-template-columns: 1fr 2fr;
    border-bottom: 1px solid var(--border);
  }

  .content-section-label {
    padding: 4rem;
    border-right: 1px solid var(--border);
    display: flex;
    align-items: flex-start;
    padding-top: 4rem;
  }

  .section-label-text {
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
    writing-mode: horizontal-tb;
  }

  .content-section-body {
    padding: 4rem;
  }

  .content-section-body h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin-bottom: 1.5rem;
    color: var(--ink);
  }

  .content-section-body p {
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.9;
    max-width: 580px;
    margin-bottom: 1.2rem;
  }

  .content-section-body p:last-child {
    margin-bottom: 0;
  }

  .highlight {
    color: var(--ink);
    font-weight: 500;
  }

  /* WHAT YOU'LL FIND */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-bottom: 1px solid var(--border);
  }

  .feature-item {
    padding: 3rem 2.5rem;
    border-right: 1px solid var(--border);
  }

  .feature-item:last-child { border-right: none; }

  .feature-emoji {
    font-size: 1.8rem;
    margin-bottom: 1rem;
    display: block;
  }

  .feature-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.6rem;
    color: var(--ink);
  }

  .feature-desc {
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.7;
  }

  /* START HERE CTA */
  .start-here {
    display: grid;
    grid-template-columns: 2fr 1fr;
    border-bottom: 1px solid var(--border);
  }

  .start-here-left {
    padding: 4rem;
    border-right: 1px solid var(--border);
  }

  .start-here-left h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 400;
    font-style: italic;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .start-here-left p {
    font-size: 0.92rem;
    color: var(--muted);
    line-height: 1.8;
    max-width: 500px;
    margin-bottom: 2rem;
  }

  .start-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 400px;
  }

  .start-link-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.2rem;
    border: 1px solid var(--border);
    text-decoration: none;
    color: var(--ink);
    font-size: 0.85rem;
    transition: all 0.2s;
  }

  .start-link-item:hover {
    border-color: var(--rust);
    background: var(--rust-light);
  }

  .start-link-item span {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--rust);
  }

  .start-here-right {
    background: var(--rust);
    padding: 4rem 3rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
  }

  .start-here-right h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--cream);
    line-height: 1.3;
  }

  .start-here-right p {
    font-size: 0.82rem;
    color: rgba(247,243,236,0.75);
    line-height: 1.6;
  }

  .btn-cream {
    display: inline-block;
    padding: 0.85rem 1.5rem;
    background: var(--cream);
    color: var(--rust);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    transition: all 0.2s;
    margin-top: 0.5rem;
    cursor: pointer;
    border: none;
    width: fit-content;
  }

  .btn-cream:hover {
    background: var(--ink);
    color: var(--cream);
  }

  /* FOOTER */
  footer {
    padding: 3rem 4rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-brand {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 700;
  }

  .footer-brand span {
    display: block;
    font-size: 0.65rem;
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 0.2rem;
  }

  .footer-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }

  .footer-links a {
    text-decoration: none;
    font-size: 0.75rem;
    color: var(--muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .footer-links a:hover { color: var(--ink); }

  @media (max-width: 900px) {
    nav { padding: 1.2rem 1.5rem; }
    .nav-links { gap: 1.2rem; }
    .about-hero { grid-template-columns: 1fr; }
    .about-hero-left { padding: 3rem 1.5rem; border-right: none; border-bottom: 1px solid var(--border); }
    .about-hero-right { padding: 3rem 1.5rem; min-height: 300px; }
    .content-section { grid-template-columns: 1fr; }
    .content-section-label { padding: 2rem 1.5rem 0; border-right: none; }
    .content-section-body { padding: 1.5rem 1.5rem 3rem; }
    .features-grid { grid-template-columns: 1fr; }
    .feature-item { border-right: none; border-bottom: 1px solid var(--border); }
    .start-here { grid-template-columns: 1fr; }
    .start-here-left { padding: 2.5rem 1.5rem; border-right: none; border-bottom: 1px solid var(--border); }
    .start-here-right { padding: 2.5rem 1.5rem; }
    footer { flex-direction: column; gap: 1.5rem; padding: 2rem 1.5rem; text-align: center; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-brand">
